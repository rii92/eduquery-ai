# BiQuery AI — Environment Configuration
# Salin file ini sebagai .env dan sesuaikan isinya.

# ── App ──
APP_HOST=0.0.0.0
APP_PORT=8000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# ── Local LLM (Ollama) ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT=60

# ── Cloud LLM (OpenRouter / OpenAI-compatible) ──
# OpenRouter: https://openrouter.ai/api/v1, isi API key dari https://openrouter.ai/keys
CLOUD_API_KEY=sk-or-v1-...
CLOUD_API_URL=https://openrouter.ai/api/v1
CLOUD_MODEL=gpt-4o-mini
CLOUD_REFERER=http://localhost:8000
CLOUD_TITLE=BP Batam Ai

# ── llama.cpp (Local GPU Server) ──
# LLAMACPP_API_URL=http://172.18.32.172:8080/v1
# LLAMACPP_MODEL=ornith-1.0-35b-Q6_K.gguf
# LLAMACPP_TIMEOUT=120

# ── Embedding Model ──
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── BP Batam Oracle (US_DWH + US_DT) ──
# Akses: us_dwh / DeWeHaRS20DuaFive @ bpdb-scan.bpbatam.go.id:1521/begs
BP_DB_USER=us_dwh
BP_DB_PASSWORD=
BP_DB_HOST=bpdb-scan.bpbatam.go.id:1521
BP_DB_SERVICE_NAME=begs

# ── iBOSS Oracle (US_oss via us_si) ──
# Akses: us_si / Integratedsystem2021 @ bpdb-scan.bpbatam.go.id:1521/begs
IBOSS_DB_USER=us_si
IBOSS_DB_PASSWORD=
IBOSS_DB_HOST=bpdb-scan.bpbatam.go.id:1521
IBOSS_DB_SERVICE_NAME=begs

# ── vOSS Oracle (BSWBY via us_voss) ──
# Akses: us_voss / Y7DOiBs3FNjUYCp @ 172.16.101.81:1521/BSWBY
VOSS_DB_USER=us_voss
VOSS_DB_PASSWORD=
VOSS_DB_HOST=172.16.101.81:1521
VOSS_DB_SERVICE_NAME=BSWBY

# ── BCARE PostgreSQL ──
# Akses: us_ro_pg / PgProd!8Kx$47NqR2vZ @ 172.16.10.126:5181/bcare
BCARE_DB_HOST=172.16.10.126
BCARE_DB_PORT=5181
BCARE_DB_NAME=bcare
BCARE_DB_USER=us_ro_pg
BCARE_DB_PASSWORD=

# ── Database Type ──
DB_TYPE=oracle
# SQLITE_DB_PATH=data/biquery.db
