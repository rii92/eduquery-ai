# EduQuery AI — Environment Configuration
# Salin file ini sebagai .env dan sesuaikan isinya.

# ── App ──
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Local LLM (Ollama) ──
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT=60

# ── Cloud LLM (OpenRouter / OpenAI-compatible) ──
# OpenRouter: https://openrouter.ai/api/v1, isi API key dari https://openrouter.ai/keys
CLOUD_API_KEY=sk-or-v1-...
CLOUD_API_URL=https://openrouter.ai/api/v1
CLOUD_MODEL=gpt-4o-mini
CLOUD_REFERER=http://localhost:8000
CLOUD_TITLE=EduQuery AI

# ── Embedding Model ──
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Database (oracle / sqlite) ──
DB_TYPE=oracle
# SQLITE_DB_PATH=data/eduquery.db

# ── BP Batam Oracle ──
BP_DB_USER=us_dwh
BP_DB_PASSWORD=DeWeHaRS20DuaFive
BP_DB_HOST=bpdb-scan.bpbatam.go.id:1521
BP_DB_SERVICE_NAME=begs
