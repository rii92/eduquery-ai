{
  "insight_template_guide": {
    "output_contract": {
      "type": "object",
      "required": [
        "insight",
        "bullets",
        "caveats"
      ],
      "properties": {
        "insight": {
          "type": "string",
          "max_sentences": 2
        },
        "bullets": {
          "type": "array",
          "max_items": 6,
          "item_type": "string"
        },
        "caveats": {
          "type": "array",
          "max_items": 4,
          "item_type": "string"
        }
      }
    },
    "global_rules": [
      "Gunakan hanya fakta yang ada di INPUT_FACTS_JSON.",
      "Jangan menebak penyebab / alasan / konteks di luar data.",
      "Jika nilai tidak tersedia, hilangkan bagian itu (jangan mengarang).",
      "Utamakan angka + kualifier singkat dibanding narasi panjang.",
      "Jika memungkinkan, tambahkan 1 bullet yang diawali 'Saran:' berisi tindak lanjut yang relevan."
    ],
    "language": "id",
    "intent_rules": {
      "bp_all_kpi_card": {
        "insight_patterns": [
          "Total {total_dokumen} dokumen dengan {total_terbit} terbit, {total_tolak} ditolak, {total_dalam_proses} dalam proses, dan {total_overdue} overdue."
        ],
        "bullet_patterns": [
          "Terbit: {total_terbit} dari {total_dokumen} ({persen_terbit}%).",
          "Ditolak: {total_tolak}.",
          "Dalam Proses: {total_dalam_proses}.",
          "Overdue: {total_overdue}.",
          "Saran: filter per jenis izin atau periode untuk analisis lebih lanjut."
        ],
        "facts_to_use": ["numeric", "filters", "row_count"]
      },
      "bp_flow_permohonan": {
        "insight_patterns": [
          "{row_count} aliran data pada diagram Sankey."
        ],
        "bullet_patterns": [
          "Total aliran: {row_count} baris.",
          "Saran: filter jenis izin untuk fokus pada satu kategori."
        ],
        "facts_to_use": ["filters", "row_count"]
      },
      "bp_tren_inflow_outflow": {
        "insight_patterns": [
          "Tren inflow vs outflow pada {period_count} periode."
        ],
        "bullet_patterns": [
          "Terakhir ({latest_period}): inflow {inflow_value}, outflow {outflow_value}.",
          "Saran: filter rentang tanggal untuk periode spesifik."
        ],
        "facts_to_use": ["series", "filters", "row_count", "numeric"]
      },
      "bp_gauge_performa": {
        "insight_patterns": [
          "Performa penyelesaian: {performa_penyelesaian}."
        ],
        "bullet_patterns": [
          "Skor performa: {performa_penyelesaian}.",
          "Saran: bandingkan antar jenis izin."
        ],
        "facts_to_use": ["numeric", "filters", "row_count"]
      },
      "bp_kepatuhan_sla": {
        "insight_patterns": [
          "Kepatuhan SLA: {kepatuhan_sla}."
        ],
        "bullet_patterns": [
          "Skor SLA: {kepatuhan_sla}.",
          "Saran: identifikasi faktor penyebab ketidakpatuhan SLA."
        ],
        "facts_to_use": ["numeric", "filters", "row_count"]
      },
      "bp_funnel_kemacetan": {
        "insight_patterns": [
          "{row_count} tahapan funnel dengan total kemacetan."
        ],
        "bullet_patterns": [
          "Tahapan teratas: {top_entity} = {top_value} dokumen.",
          "Saran: fokus pada tahap dengan penurunan tertinggi."
        ],
        "facts_to_use": ["ranking", "filters", "row_count", "numeric"]
      },
      "bp_proporsi_kerja": {
        "insight_patterns": [
          "{row_count} kategori proporsi kerja staf."
        ],
        "bullet_patterns": [
          "Kategori terbanyak: {top_entity} = {top_value}.",
          "Saran: evaluasi keseimbangan beban kerja."
        ],
        "facts_to_use": ["ranking", "filters", "row_count", "numeric"]
      },
      "bp_rapor_staf": {
        "insight_patterns": [
          "{row_count} staf dievaluasi dengan skor akhir."
        ],
        "bullet_patterns": [
          "Staf terbaik: {top_entity} skor {top_value}.",
          "Saran: berikan pelatihan untuk staf dengan skor rendah."
        ],
        "facts_to_use": ["ranking", "filters", "row_count", "numeric"]
      },
      "_default": {
        "insight_patterns": [
          "{row_count} baris hasil."
        ],
        "bullet_patterns": [
          "Baris hasil: {row_count}.",
          "Saran: tambah filter (tanggal/jenis izin) agar hasil lebih spesifik."
        ],
        "facts_to_use": [
          "row_count",
          "filters",
          "ranking",
          "numeric",
          "series"
        ]
      }
    }
  }
}
