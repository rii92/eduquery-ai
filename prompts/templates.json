{
  "insight_template_guide": {
    "output_contract": {
      "type": "object",
      "required": [
        "insight",
        "bullets",
        "caveats"
      ],
      "properties": {
        "insight": {
          "type": "string",
          "max_sentences": 2
        },
        "bullets": {
          "type": "array",
          "max_items": 6,
          "item_type": "string"
        },
        "caveats": {
          "type": "array",
          "max_items": 4,
          "item_type": "string"
        }
      }
    },
    "global_rules": [
      "Gunakan hanya fakta yang ada di INPUT_FACTS_JSON.",
      "Jangan menebak penyebab / alasan / konteks di luar data.",
      "Jika nilai tidak tersedia, hilangkan bagian itu (jangan mengarang).",
      "Utamakan angka + kualifier singkat dibanding narasi panjang.",
      "Jika memungkinkan, tambahkan 1 bullet yang diawali 'Saran:' berisi tindak lanjut yang relevan."
    ],
    "language": "id",
